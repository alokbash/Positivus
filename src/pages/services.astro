---
import MainLayout from "../layouts/MainLayout.astro";
import Card from "../components/ui/Card.astro";

const services = [
  {
    titleTop: "Developer & API",
    titleBottom: "documentation",
    description: "We create clean, easy-to-use API documentation that developers actually enjoy working with. With clear endpoint descriptions, real-world examples, and quickstart guides, we make your APIs simple to understand and fast to integrate.",
    benefits: [
      "Faster developer onboarding",
      "Smoother integrations",
      "Better developer experience",
      "Higher API adoption"
    ],
    cta: "Get API documentation audit",
    link: "/contact",
  },
  {
    titleTop: "Software documentation",
    titleBottom: "and online help",
    description: "We turn complex products into simple, helpful documentation your users can rely on. Whether it’s tutorials, help centers, or user guides, we focus on clarity, structure, and usability.",
    benefits: [
      "Fewer support tickets",
      "Happier users",
      "Faster product adoption",
      "Clear, consistent guidance"
    ],
    cta: "Get documentation review",
    link: "/contact",
  },
  {
    titleTop: "Docs-as-code for",
    titleBottom: "software documentation",
    description: "We help you treat documentation like code: versioned, collaborative, and always in sync with your product. We set up workflows that scale as your team grows.",
    benefits: [
      "Documentation that stays up to date",
      "Seamless team collaboration",
      "Faster release cycles",
      "Scalable workflows"
    ],
    cta: "Set up docs-as-code",
    link: "/contact",
  },
  {
    titleTop: "DITA-XML for",
    titleBottom: "documentation",
    description: "For teams dealing with large or complex documentation, we implement structured content using DITA-XML. Your content becomes reusable, consistent, and easier to manage.",
    benefits: [
      "Reusable content blocks",
      "Consistent structure",
      "Easier scaling",
      "Efficient content management"
    ],
    cta: "Start DITA implementation",
    link: "/contact",
  },
  {
    titleTop: "Developer portal",
    titleBottom: "setup",
    description: "We design developer portals that are simple, intuitive, and built for growth. Developers find what they need faster and get started without friction.",
    benefits: [
      "One central hub for developers",
      "Better onboarding experience",
      "Increased engagement",
      "Scales with your product"
    ],
    cta: "Build your developer portal",
    link: "/contact",
  },
  {
    titleTop: "Ongoing documentation",
    titleBottom: "maintenance",
    description: "We keep your documentation up to date with every release, fixing gaps and improving clarity so your content always reflects your product.",
    benefits: [
      "Always current documentation",
      "Less internal effort",
      "Consistent quality",
      "Reliable source of truth"
    ],
    cta: "Request maintenance plan",
    link: "/contact",
  },
];
---

<MainLayout title="Our services | Agiliya">
  <div class="py-16 px-4 mx-auto max-w-screen-xl lg:py-24 lg:px-6">

    <!-- HEADER -->
    <div class="text-center mb-16">
      <h1 class="mb-4 text-5xl font-medium md:text-6xl">Our services</h1>
      <p class="text-xl max-w-3xl mx-auto">
        Clear, scalable documentation services designed to help your product grow and your developers move faster.
      </p>
    </div>

    <!-- SERVICES -->
    <div>
      {services.map((service, i) => (
        <div class={`py-20 ${i % 2 === 1 ? 'bg-alt -mx-4 px-4 md:-mx-6 md:px-6' : ''}`}>

          <div class="grid md:grid-cols-2 gap-12 items-start max-w-6xl mx-auto">

            <!-- LEFT -->
            <div>
              <h3 class="text-3xl font-semibold mb-4">
                {service.titleTop} {service.titleBottom}
              </h3>

              <p class="mb-6 leading-relaxed text-gray-700">
                {service.description}
              </p>

              <a
                href={service.link}
                class="inline-flex items-center px-8 py-4 bg-green text-dark rounded-2xl hover:bg-dark hover:text-white transition-all font-medium"
              >
                {service.cta}
              </a>
            </div>

            <!-- RIGHT -->
            <div class="bg-white border border-gray-200 rounded-2xl p-8">
              <h3 class="text-2xl font-medium mb-4">Benefits</h3>
              <ul class="space-y-4">
                {service.benefits.map((benefit) => (
                  <li class="flex items-start">
                    <svg class="mr-2 w-5 h-5 mt-1 text-green" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                    <span>{benefit}</span>
                  </li>
                ))}
              </ul>
            </div>

          </div>
        </div>
      ))}
    </div>

    <!-- FINAL CTA -->
    <div class="mt-24 text-center">
      <Card>
        <div class="p-10 md:p-16">
          <h2 class="text-3xl md:text-4xl font-medium mb-6">
            Ready to improve your documentation?
          </h2>
          <p class="mb-10 text-xl max-w-2xl mx-auto">
            Let’s build documentation that developers love and your product deserves.
          </p>
          <a href="/contact" class="inline-flex items-center px-10 py-5 bg-dark text-white rounded-2xl hover:bg-green hover:text-dark transition-all font-medium text-xl">
            Contact us →
          </a>
        </div>
      </Card>
    </div>

  </div>
</MainLayout>

<style>
  .bg-alt {
    background-color: #f8fafc;
  }
</style>