---
import SectionTitle from "../ui/SectionTitle.astro";
import ServiceCard from "../ui/ServiceCard.astro";
import Section from "./Section.astro";

// ✅ Define Variant type
type Variant = "light" | "accent" | "dark";

// ✅ Define Card type
interface Card {
  titleTop: string;
  titleBottom: string;
  text: string;
  link: string;
  variant: Variant;
}

// ✅ Type the array (THIS fixes your error)
const cards: Card[] = [
  {
    titleTop: "Developer and",
    titleBottom: "API documentation",
    text: "Clear, well-structured API references that make integration fast and simple.",
    link: "/services",
    variant: "light",
  },
  {
    titleTop: "Software documentation",
    titleBottom: "and online help",
    text: "User-friendly documentation for tutorials, manuals, and help centers.",
    link: "/services",
    variant: "accent",
  },
  {
    titleTop: "Docs-as-code for your",
    titleBottom: "software documentation",
    text: "Versioned, scalable documentation workflows aligned with your codebase.",
    link: "/services",
    variant: "dark",
  },
  {
    titleTop: "DITA-XML for",
    titleBottom: "documentation",
    text: "Structured content systems for scalable and reusable documentation.",
    link: "/services",
    variant: "light",
  },
  {
    titleTop: "Developer",
    titleBottom: "portal setup",
    text: "Design developer portals that are intuitive and scalable.",
    link: "/services",
    variant: "accent",
  },
  {
    titleTop: "Ongoing",
    titleBottom: "documentation maintenance",
    text: "Keep your docs accurate and aligned with every release.",
    link: "/services",
    variant: "dark",
  },
];

const description =
  "Professional developer documentation services that help teams ship faster with clarity.";
---

<Section id="services">
  <div class="mt-[120px] mb-10">

    <SectionTitle
      sectionTitle="Services"
      description={description}
    />

    <div class="grid md:grid-cols-2 gap-6 mt-12">
      {cards.map((card) => (
        <ServiceCard {...card} />
      ))}
    </div>

  </div>
</Section>