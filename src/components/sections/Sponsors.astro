---
import { Image } from "astro:assets";
import apaleo from "../../assets/company/apaleo.png";
import autto from "../../assets/company/autto.png";
import chromia from "../../assets/company/chromia.png";
import smsMagic from "../../assets/company/sms-magic.png";
import sunrise from "../../assets/company/sunrise.png";
import Section from "./Section.astro";

const sponsors = [
  { logo: chromia, alt: "Chromia logo" },
  { logo: apaleo, alt: "Apaleo logo" },
  { logo: smsMagic, alt: "SMS-Magic logo" },
  { logo: sunrise, alt: "Sunrise Integration logo" },
  { logo: autto, alt: "Autto logo" },
];
---

<Section id="sponsors">
  <div class="text-center mb-10">
    <p class="text-sm text-gray-500">
      Trusted by product teams
    </p>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-6 items-center">

    {
      sponsors.map((sponsor) => {
        return (
          <div class="flex justify-center items-center h-16">
            <Image
              src={sponsor.logo}
              alt={sponsor.alt}
              loading="lazy"
              class="max-h-10 max-w-[140px] w-auto object-contain"
            />
          </div>
        );
      })
    }

  </div>
</Section>