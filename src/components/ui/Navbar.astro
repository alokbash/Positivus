---
import { Astronav } from "astro-navbar";

const menuitems = [
  { href: '/services', label: 'Services' },
  { href: '/process', label: 'Process' },
  { href: '/about', label: 'About us' },
  { href: '/contact', label: 'Contact' },
];

const navButton = { href: '#', label: 'Book a Call' };
---

<div class="mt-20">
  <nav class="navbar fixed top-0 left-0 w-full z-50">
    <header class="flex flex-col lg:flex-row justify-between items-center py-4 px-6 md:px-32">

      <Astronav>
        <div class="flex w-full lg:w-auto items-center justify-between">

          <!-- LOGO -->
          <a href="/" class="flex items-center">
            <img src="/Logo.png" class="logo" alt="Agiliya logo" />
          </a>

          <!-- MOBILE MENU ICON -->
          <div class="block lg:hidden">
            <div id="menu-icon" class="w-8 h-8 cursor-pointer text-black">
              <svg id="open-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
              <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="hidden">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </div>
          </div>
        </div>

        <!-- MENU -->
        <nav id="menu-items" class="hidden w-full lg:flex lg:w-auto lg:mt-0">
          <ul class="menu">
            {menuitems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="nav-link"
                  data-close-menu="true"
                >
                  {item.label}
                </a>
              </li>
            ))}

            <!-- MOBILE CTA -->
            <div class="lg:hidden flex justify-center mt-4">
              <a href={navButton.href} class="cta-mobile" data-close-menu="true">
                {navButton.label}
              </a>
            </div>
          </ul>
        </nav>
      </Astronav>

      <!-- DESKTOP CTA -->
      <div class="hidden lg:flex">
        <a href={navButton.href} class="cta">
          {navButton.label}
        </a>
      </div>

    </header>
  </nav>
</div>

<style>
  /* NAVBAR BACKGROUND */
  .navbar {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #e5e7eb;
  }

  /* LOGO */
  .logo {
    height: 42px;
    width: auto;
  }

  /* MENU */
  .menu {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 16px;
  }

  @media (min-width: 1024px) {
    .menu {
      flex-direction: row;
      align-items: center;
      gap: 40px;
      padding: 0;
    }
  }

  /* NAV LINKS */
  .nav-link {
    position: relative;
    font-size: 16px;
    font-weight: 500;
    color: #111827;
    text-decoration: none;
    transition: 0.2s;
  }

  .nav-link:hover {
    opacity: 0.7;
  }

  /* ACTIVE / HOVER UNDERLINE */
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 0%;
    height: 2px;
    background: #84cc16;
    transition: width 0.25s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  /* CTA BUTTON */
  .cta {
    background: #84cc16;
    color: #111827;
    padding: 12px 22px;
    border-radius: 999px;
    font-size: 15px;
    font-weight: 500;
    transition: 0.2s;
  }

  .cta:hover {
    background: #65a30d;
    color: white;
  }

  /* MOBILE CTA */
  .cta-mobile {
    background: #84cc16;
    color: #111827;
    padding: 14px 24px;
    border-radius: 999px;
    font-weight: 500;
  }
</style>

<script is:inline>
  const menuIcon = document.getElementById('menu-icon');
  const openIcon = document.getElementById('open-icon');
  const closeIcon = document.getElementById('close-icon');
  const menuItems = document.getElementById('menu-items');
  const closeMenuItems = document.querySelectorAll('[data-close-menu="true"]');

  menuIcon.addEventListener('click', () => {
    menuItems.classList.toggle('hidden');
    openIcon.classList.toggle('hidden');
    closeIcon.classList.toggle('hidden');
  });

  closeMenuItems.forEach(item => {
    item.addEventListener('click', () => {
      menuItems.classList.add('hidden');
      openIcon.classList.remove('hidden');
      closeIcon.classList.add('hidden');
    });
  });
</script>