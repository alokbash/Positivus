---
import { Image } from "astro:assets";
import Logo from "../../assets/logo-alt.png";
import Linkedin from "../../assets/linkedin.svg";
---

<footer class="footer">
  <div class="container">

    <!-- GRID -->
    <div class="grid">

      <!-- BRAND -->
      <div>
        <div class="brand">
          <Image src={Logo} alt="Agiliya logo" class="logo" />
        </div>

        <p class="tagline">
          Documentation services for modern product teams.
        </p>

        <a href="/contact" class="cta">Partner with us</a>
      </div>

      <!-- SERVICES -->
      <div>
        <h4>Services</h4>
        <ul>
          <li><a href="/services">Developer & API documentation</a></li>
          <li><a href="/services">Software documentation</a></li>
          <li><a href="/services">Docs-as-code</a></li>
          <li><a href="/services">Developer portals</a></li>
        </ul>
      </div>

      <!-- COMPANY -->
      <div>
        <h4>Company</h4>
        <ul>
          <li><a href="/about">About us</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <!-- SUBSCRIBE -->
      <div>
        <h4>Subscribe</h4>
        <p class="newsletter-text">
          Get insights on documentation and developer experience.
        </p>

        <div class="newsletter">
          <a
            href="https://agiliya.substack.com/"
            target="_blank"
            class="subscribe-btn"
          >
            Subscribe →
          </a>
        </div>
      </div>

    </div>

    <!-- BOTTOM -->
    <div class="bottom">
      <span>© 2026 Agiliya. Built for engineering teams.</span>

      <div class="socials">
        <a href="https://linkedin.com" target="_blank">
          <Image src={Linkedin} alt="LinkedIn" />
        </a>
      </div>
    </div>

  </div>
</footer>

<style>
  .footer {
    background-color: #ecfdf5;
    color: #1f2937;
    padding: 60px 20px 30px;
    border-top: 1px solid #d1fae5;
  }

  .container {
    max-width: 1200px;
    margin: auto;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }

  .brand {
    margin-bottom: 10px;
  }

  .logo {
    height: 36px;
    width: auto;
  }

  .tagline {
    margin: 10px 0 20px;
    font-size: 14px;
    color: #4b5563;
  }

  .cta {
    display: inline-block;
    background: #84cc16;
    color: #111827;
    padding: 10px 18px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
  }

  .cta:hover {
    background: #65a30d;
    color: white;
  }

  h4 {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 15px;
    color: #111827;
    /* removed uppercase for sentence case */
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  ul a {
    font-size: 14px;
    color: #374151;
    text-decoration: none;
  }

  ul a:hover {
    color: #84cc16;
  }

  .newsletter-text {
    font-size: 14px;
    margin-bottom: 15px;
    color: #4b5563;
  }

  .newsletter {
    display: flex;
    gap: 10px;
  }

  .subscribe-btn {
    display: inline-block;
    background: #84cc16;
    color: #111827;
    padding: 10px 18px;
    border-radius: 999px;
    font-weight: 500;
    text-decoration: none;
  }

  .subscribe-btn:hover {
    background: #65a30d;
    color: white;
  }

  .bottom {
    border-top: 1px solid #d1fae5;
    margin-top: 40px;
    padding-top: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
  }

  .socials img {
    width: 18px;
    opacity: 0.7;
  }

  .socials img:hover {
    opacity: 1;
  }
</style>