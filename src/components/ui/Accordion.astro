---
import AccordionItem from "./AccordionItem.astro";

const content = [
{
  index: 1,
  title: "Project Kickoff and Planning",
  description: "While co-location is ideal for Agile teams, it's often not feasible for technical writers. We begin each project with a kick-off meeting to review documentation scope, backlogs, release goals, and create a communication plan. We agree on the planning tool to track tasks and present documentation at the end of the sprint."
},
{
  index: 2,
  title: "Backlog Review and Task Definition",
  description: "After setting the communication plan, we review the product backlog and conduct a product audit to assess current documentation and new requirements. We define tasks, get client sign-off, and agree on tools, source control, and delivery methods."
},
{
  index: 3,
  title: "User Analysis and Document Structuring",
  description: "We analyze user personas and product usage before creating documentation. We draft a TOC for each document, focusing on three information types: Concept, Task, and Reference. Once approved, we move into sprints."
},
{
  index: 4,
  title: "Template Creation and Writing Standards",
  description: "We build document templates that follow brand guidelines and favor minimalism so users can find information quickly. Our writers often use DITA and docs-as-code. We also create a style guide to ensure consistency across all documentation, covering tone, voice, formatting, and terminology."
},
{
  index: 5,
  title: "Collaboration and Sprint Execution",
  description: "As part of scrum teams, we attend planning meetings, create documentation tasks, and author self-contained topics. We use collaboration tools to gather input, send drafts for technical review, and encourage marking user stories as NOT DONE if documentation is incomplete."
},
{
  index: 6,
  title: "Review, Approval, and Publication",
  description: "We rigorously review writing, graphics, and links for accuracy and style. At sprint review, we demo the documentation, and once accepted, we publish it."
}
];
---

{
  content.map((item) => {
    return (
      <AccordionItem
        index={item.index}
        title={item.title}
        description={item.description}
      />
    );
  })
}
