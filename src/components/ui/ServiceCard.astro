---
import { Image } from "astro:assets";

import gob from "../../assets/icon6.svg";
import wob from "../../assets/icon7.svg";

type Variant = "light" | "accent" | "dark";

interface Props {
  titleTop: string;
  titleBottom: string;
  text?: string;
  link?: string;
  variant?: Variant;
}

const {
  titleTop,
  titleBottom,
  text,
  link = "#",
  variant = "light",
} = Astro.props as Props;

// ✅ strongly typed variants
const variants: Record<Variant, string> = {
  light: "bg-light text-black",
  accent: "bg-green text-black",
  dark: "bg-dark text-white",
};

// ✅ SAFETY: fallback if something unexpected comes
const safeVariant: Variant =
  variant in variants ? variant : "light";

const icon = safeVariant === "dark" ? wob : gob;
---

<a href={link} class={`service-card ${variants[safeVariant]} group`}>
  <div class="flex flex-col h-full gap-4">

    <!-- Title -->
    <h3 class="text-xl font-semibold leading-snug">
      {titleTop} <br /> {titleBottom}
    </h3>

    <!-- Description -->
    {text && (
      <p
        class={`text-sm max-w-md ${
          safeVariant === "dark" ? "text-gray-200" : "text-gray-700"
        }`}
      >
        {text}
      </p>
    )}

    <!-- Arrow -->
    <div class="mt-auto pt-4">
      <Image
        src={icon}
        alt=""
        class="transition-transform group-hover:translate-x-1"
      />
    </div>

  </div>
</a>

<style>
  .service-card {
    @apply block w-full p-8 sm:p-10 rounded-3xl transition-all duration-300;
    border: 1px solid #e5e7eb;
  }

  .bg-light {
    background-color: #f1f5f9;
  }

  .bg-green {
    background-color: #a3e635;
  }

  .bg-dark {
    background-color: #3f4a5a;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.06);
  }
</style>